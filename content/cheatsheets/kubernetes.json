{
  "slug": "kubernetes",
  "label": "Kubernetes",
  "color": "violet",
  "description": "kubectl commands for pods, deployments, services, config, RBAC, and cluster management.",
  "sections": [
    {
      "title": "Cluster & Context",
      "commands": [
        { "cmd": "kubectl version --short", "desc": "Client and server version" },
        { "cmd": "kubectl cluster-info", "desc": "Cluster API server and DNS endpoints" },
        { "cmd": "kubectl get nodes", "desc": "List all nodes" },
        { "cmd": "kubectl get nodes -o wide", "desc": "Nodes with IP, OS, kernel info" },
        { "cmd": "kubectl config get-contexts", "desc": "List all kubeconfig contexts" },
        { "cmd": "kubectl config use-context my-cluster", "desc": "Switch active context" },
        { "cmd": "kubectl config current-context", "desc": "Show current context name" },
        { "cmd": "kubectl config set-context --current --namespace=dev", "desc": "Set default namespace for current context" }
      ]
    },
    {
      "title": "Pods",
      "commands": [
        { "cmd": "kubectl get pods", "desc": "List pods in default namespace" },
        { "cmd": "kubectl get pods -n kube-system", "desc": "List pods in specific namespace" },
        { "cmd": "kubectl get pods -A", "desc": "List pods across all namespaces" },
        { "cmd": "kubectl get pods -o wide", "desc": "Pods with node and IP info" },
        { "cmd": "kubectl get pods -l app=nginx", "desc": "Filter pods by label" },
        { "cmd": "kubectl describe pod mypod", "desc": "Full pod details, events, conditions" },
        { "cmd": "kubectl logs mypod", "desc": "View pod logs" },
        { "cmd": "kubectl logs -f mypod", "desc": "Follow logs in real time" },
        { "cmd": "kubectl logs mypod -c mycontainer", "desc": "Logs from specific container in pod" },
        { "cmd": "kubectl logs mypod --previous", "desc": "Logs from previous (crashed) container" },
        { "cmd": "kubectl exec -it mypod -- bash", "desc": "Interactive shell inside pod" },
        { "cmd": "kubectl exec mypod -- cat /etc/hosts", "desc": "Run one-off command in pod" },
        { "cmd": "kubectl delete pod mypod", "desc": "Delete pod (will be recreated by Deployment)" },
        { "cmd": "kubectl delete pod mypod --force --grace-period=0", "desc": "Force delete stuck pod" },
        { "cmd": "kubectl get pod mypod -o yaml", "desc": "Get full pod YAML manifest" }
      ]
    },
    {
      "title": "Deployments",
      "commands": [
        { "cmd": "kubectl get deployments", "desc": "List all deployments" },
        { "cmd": "kubectl create deployment nginx --image=nginx:1.25", "desc": "Create deployment imperatively" },
        { "cmd": "kubectl scale deployment nginx --replicas=3", "desc": "Scale deployment to 3 replicas" },
        { "cmd": "kubectl set image deployment/nginx nginx=nginx:1.26", "desc": "Update container image (rolling update)" },
        { "cmd": "kubectl rollout status deployment/nginx", "desc": "Watch rollout progress" },
        { "cmd": "kubectl rollout history deployment/nginx", "desc": "Show rollout revision history" },
        { "cmd": "kubectl rollout undo deployment/nginx", "desc": "Rollback to previous revision" },
        { "cmd": "kubectl rollout undo deployment/nginx --to-revision=2", "desc": "Rollback to specific revision" },
        { "cmd": "kubectl rollout pause deployment/nginx", "desc": "Pause rollout mid-way" },
        { "cmd": "kubectl rollout resume deployment/nginx", "desc": "Resume paused rollout" },
        { "cmd": "kubectl delete deployment nginx", "desc": "Delete deployment and its pods" }
      ]
    },
    {
      "title": "Services & Networking",
      "commands": [
        { "cmd": "kubectl get services", "desc": "List all services" },
        { "cmd": "kubectl expose deployment nginx --port=80 --type=ClusterIP", "desc": "Expose deployment as ClusterIP service" },
        { "cmd": "kubectl expose deployment nginx --port=80 --type=NodePort", "desc": "Expose as NodePort (accessible outside cluster)" },
        { "cmd": "kubectl expose deployment nginx --port=80 --type=LoadBalancer", "desc": "Expose via cloud load balancer" },
        { "cmd": "kubectl port-forward svc/nginx 8080:80", "desc": "Forward local port 8080 to service port 80" },
        { "cmd": "kubectl port-forward pod/mypod 5000:5000", "desc": "Port forward directly to pod" },
        { "cmd": "kubectl get ingress -A", "desc": "List all ingress rules" },
        { "cmd": "kubectl get endpoints nginx", "desc": "Show which pods a service routes to" }
      ]
    },
    {
      "title": "ConfigMaps & Secrets",
      "commands": [
        { "cmd": "kubectl get configmaps", "desc": "List all configmaps" },
        { "cmd": "kubectl create configmap app-config --from-file=config.env", "desc": "Create configmap from file" },
        { "cmd": "kubectl create configmap app-config --from-literal=DB_HOST=localhost", "desc": "Create configmap from literal key=value" },
        { "cmd": "kubectl describe configmap app-config", "desc": "View configmap contents" },
        { "cmd": "kubectl get secrets", "desc": "List all secrets" },
        { "cmd": "kubectl create secret generic db-secret --from-literal=password=S3cr3t!", "desc": "Create opaque secret" },
        { "cmd": "kubectl create secret docker-registry regcred --docker-server=ghcr.io --docker-username=user --docker-password=TOKEN", "desc": "Create image pull secret" },
        { "cmd": "kubectl get secret db-secret -o jsonpath='{.data.password}' | base64 -d", "desc": "Decode and read secret value" }
      ]
    },
    {
      "title": "Namespaces & RBAC",
      "commands": [
        { "cmd": "kubectl get namespaces", "desc": "List all namespaces" },
        { "cmd": "kubectl create namespace dev", "desc": "Create namespace" },
        { "cmd": "kubectl delete namespace dev", "desc": "Delete namespace and everything in it" },
        { "cmd": "kubectl get serviceaccounts -n dev", "desc": "List service accounts in namespace" },
        { "cmd": "kubectl get roles,rolebindings -n dev", "desc": "List RBAC roles in namespace" },
        { "cmd": "kubectl get clusterroles,clusterrolebindings", "desc": "List cluster-wide RBAC" },
        { "cmd": "kubectl auth can-i create pods --as=system:serviceaccount:dev:mysa", "desc": "Check if service account has permission" }
      ]
    },
    {
      "title": "Apply & Debug",
      "commands": [
        { "cmd": "kubectl apply -f manifest.yaml", "desc": "Apply/update resource from YAML" },
        { "cmd": "kubectl apply -f ./k8s/", "desc": "Apply all YAMLs in directory" },
        { "cmd": "kubectl delete -f manifest.yaml", "desc": "Delete resources defined in YAML" },
        { "cmd": "kubectl diff -f manifest.yaml", "desc": "Preview changes before applying" },
        { "cmd": "kubectl get events -n dev --sort-by=.lastTimestamp", "desc": "Recent events, sorted by time" },
        { "cmd": "kubectl top nodes", "desc": "Node CPU and memory usage" },
        { "cmd": "kubectl top pods -A", "desc": "Pod CPU and memory usage across all namespaces" },
        { "cmd": "kubectl debug pod/mypod --image=busybox --copy-to=debug-pod", "desc": "Create debug copy of pod with tools" },
        { "cmd": "kubectl run tmp --image=busybox --rm -it -- sh", "desc": "Quick throwaway debug pod" },
        { "cmd": "kubectl get all -n dev", "desc": "Get all resources in a namespace" }
      ]
    }
  ]
}
